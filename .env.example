# =============================================================================
# VEROKT - EXEMPLO DE CONFIGURACAO LOCAL
# =============================================================================
# 1. Copie este arquivo para .env
# 2. Preencha suas API keys
# 3. Rode: docker compose up -d && pnpm db:push && pnpm dev
# =============================================================================

# -----------------------------------------------------------------------------
# Database (desenvolvimento local)
# -----------------------------------------------------------------------------
# Padrao: Postgres 17 com pgvector, subido pelo docker-compose.yml local
DATABASE_URL=postgresql://verokt:verokt@localhost:5432/verokt

# -----------------------------------------------------------------------------
# Database (producao - usado pelo docker-compose.prod.yml)
# -----------------------------------------------------------------------------
POSTGRES_USER=verokt
POSTGRES_PASSWORD=verokt
POSTGRES_DB=verokt

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Padrao: Redis subido pelo docker-compose.yml local
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
BACKEND_PORT=3000

# -----------------------------------------------------------------------------
# Frontend (producao)
# -----------------------------------------------------------------------------
FRONTEND_PORT=80

# -----------------------------------------------------------------------------
# OpenAI - OBRIGATORIO para embeddings
# -----------------------------------------------------------------------------
# Pegue sua key em: https://platform.openai.com/api-keys
# Voce precisa ter um metodo de pagamento configurado.
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Provider OpenAI-Compatible - tarefas simples (scraping-analysis, pricing)
# -----------------------------------------------------------------------------
# Padrao recomendado: Yolo-Auto (OpenAI-compatible, plano flat-rate)
#   Crie em: https://yolo-auto.com/signup
#   Docs:   https://yolo-auto.com/docs
#   Modelo: qwen3.6-35b-a3b
#
# Outras opcoes:
#   DeepSeek:  https://platform.deepseek.com/api_keys
#   Groq:      https://console.groq.com/keys
#   Ollama:    http://localhost:11434/v1
COMPATIBLE_PROVIDER_NAME=yolo-auto
COMPATIBLE_BASE_URL=https://yolo-auto.com/v1
COMPATIBLE_API_KEY=  # sua key yolo_...
COMPATIBLE_MODELS=qwen3.6-35b-a3b
COMPATIBLE_MODEL=qwen3.6-35b-a3b

# -----------------------------------------------------------------------------
# Provider Nativo - tarefas complexas (SWOT, summary)
# -----------------------------------------------------------------------------
# Atualmente suportado: anthropic
# Para adicionar outros, edite packages/backend/src/config/ai-providers.ts
#
# Anthropic:
#   Crie em: https://console.anthropic.com/settings/keys
#   NATIVE_MODEL=claude-sonnet-4-20250514
NATIVE_PROVIDER=anthropic
NATIVE_API_KEY=sk-ant-...
NATIVE_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# JWT - para sessoes de usuario
# -----------------------------------------------------------------------------
# Local: qualquer string serve
# Producao: use um secret longo e aleatorio (ex: openssl rand -hex 32)
JWT_SECRET=change-me-in-production
