    "test:watch": "turbo test:watch",
    "test:coverage": "turbo test:coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
