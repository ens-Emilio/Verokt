{
  "name": "verokt",
  "private": true,
  "version": "0.0.1",
  "description": "Pesquisador Autonomo - RFP/Concorrencia",
  "scripts": {
    "dev": "turbo dev",
    "dev:backend": "turbo dev --filter=@verokt/backend",
    "dev:frontend": "turbo dev --filter=@verokt/frontend",
    "build": "turbo build",
    "db:push": "turbo db:push --filter=@verokt/backend",
    "db:migrate": "turbo db:migrate --filter=@verokt/backend",
    "db:studio": "turbo db:studio --filter=@verokt/backend",
